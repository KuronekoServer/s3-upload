# S3互換ストレージ 接続設定
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=your-bucket-name

# エンドポイント URL (必須)
# 例: Wasabi         https://s3.ap-northeast-1.wasabisys.com
# 例: MinIO          https://minio.example.com
# 例: Cloudflare R2  https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://s3.ap-northeast-1.wasabisys.com

# レスポンスの url に使う公開 URL ベース (任意)
# 例: https://s3.krnk.org
# PUBLIC_BASE_URL=https://s3.krnk.org

# リージョン (デフォルト: us-east-1)
# S3_REGION=us-east-1

# サーバーポート (デフォルト: 8080)
# PORT=8080

# 同時アップロード上限 (デフォルト: 10)
# MAX_CONCURRENT_UPLOADS=10

# 高速アップロード設定
# パートサイズ MB (デフォルト: 32) — 大きいほど往復回数が減り高速になる (最小5)
# メモリ消費目安: UPLOAD_PART_SIZE_MB × UPLOAD_CONCURRENCY × MAX_CONCURRENT_UPLOADS
# UPLOAD_PART_SIZE_MB=32

# 1ファイルあたりの並列パート数 (デフォルト: 8) — 帯域が広いほど増やすと効果的
# UPLOAD_CONCURRENCY=8

# ヘッダー認証
# true にすると全リクエストで X-Auth-Key ヘッダーの提示が必須になります
# AUTH_ENABLED=false
# AUTH_KEY=your-secret-key-here
